# Application
APP_NAME=MindStash
APP_ENV=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://mindstash:password@localhost:5432/mindstash_db
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Security
SECRET_KEY=9Ob2Q11Ns06OrrVSEgso1Pad5VTQj+m7HcMO5ozrwyg=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/LLM APIs
ANTHROPIC_API_KEY=sk-ant-xxxxx

# AI/ML API (Development only - will switch to Anthropic in production)
# Get key from: https://aimlapi.com/app/keys
AIML_API_KEY=your-aiml-api-key-here

# CORS (JSON array format for Pydantic)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Email / Notifications
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=MindStash <noreply@mindstash.heyjaydeep.website>
APP_URL=http://localhost:3000  # Set to your frontend URL in production (e.g. https://mindstash-sooty.vercel.app)

# Google OAuth (optional — enables "Sign in with Google")
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: For production
SENTRY_DSN=
POSTHOG_API_KEY=
